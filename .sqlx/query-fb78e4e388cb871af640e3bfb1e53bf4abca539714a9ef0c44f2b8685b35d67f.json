  "query": "\n        SELECT\n            id, key_id, user_id, team_id, public_key, algorithm,\n            key_fingerprint, name, description,\n            scopes as \"scopes: Vec<String>\",\n            is_active, revoked_at, expires_at, last_used_at, use_count, created_at\n        FROM signing_keys\n        WHERE key_fingerprint = $1\n        ",
