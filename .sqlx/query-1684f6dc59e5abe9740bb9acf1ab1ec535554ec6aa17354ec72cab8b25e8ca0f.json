  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                id, team_id, user_id,\n                request_body as \"request_body!: serde_json::Value\",\n                status as \"status!: BatchJobStatus\",\n                response_body as \"response_body?: serde_json::Value\",\n                error_message,\n                request_count,\n                completed_count,\n                failed_count,\n                created_at,\n                started_at,\n                completed_at\n            FROM batch_jobs\n            WHERE status = 'pending'\n            ORDER BY created_at ASC\n            LIMIT $1\n            ",
