# Example environment configuration
# Copy this to .env and customize for your environment

# Database (devenv provides this automatically with your system username)
# Default: postgres://$USER@localhost:5432/thalamus
DATABASE_URL=postgres://your_username@localhost:5432/thalamus

# Redis (devenv provides this automatically)
REDIS_URL=redis://localhost:6379

# Server configuration
HOST=0.0.0.0
PORT=3000

# Logging
RUST_LOG=info,thalamus=debug

# OpenTelemetry (optional)
# OTEL_SDK_DISABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
