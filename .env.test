# Test environment configuration
# Uses devenv services (same ports as development)

# Database (devenv PostgreSQL on default port 5432)
# Using system username - devenv creates a superuser with your username by default
DATABASE_URL=postgres://${USER}@localhost:5432/thalmus_test

# Redis (devenv Redis on default port 6379)
REDIS_URL=redis://localhost:6379/1

# Server
HOST=127.0.0.1
PORT=3001

# Logging
RUST_LOG=thalmus=debug,sqlx=warn

# Disable OpenTelemetry in tests
OTEL_SDK_DISABLED=true
